# VOXERA Backend Configuration
# Copy this file to .env and update values as needed

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Options: development, staging, production
# Determines default values for server, CORS, WebSocket, and logging settings
ENVIRONMENT=development

# =============================================================================
# PROJECT SETTINGS
# =============================================================================
PROJECT_NAME=VOXERA Backend
API_V1_STR=/api/v1

# =============================================================================
# SERVER SETTINGS
# =============================================================================
HOST=0.0.0.0
PORT=8000

# Auto-reload on code changes (None = auto-detect from ENVIRONMENT)
# development: true, staging/production: false
RELOAD=

# Number of worker processes (None = auto-detect from ENVIRONMENT)
# development: 1, staging: 2, production: 4
WORKERS=

# =============================================================================
# CORS SETTINGS
# =============================================================================
# Allowed CORS origins (comma-separated or JSON array string)
# Empty = use environment defaults:
#   development: localhost:3000, localhost:8080
#   staging: staging.voxera.com, staging-app.voxera.com
#   production: voxera.com, app.voxera.com
# Example: http://localhost:3000,http://localhost:8080
# Example JSON: ["http://localhost:3000","http://localhost:8080"]
CORS_ORIGINS=

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# Secret key for encryption and JWT tokens (minimum 32 characters)
# IMPORTANT: Change this in production and use a strong random key
SECRET_KEY=change-this-secret-key-in-production-use-env-vars-min-32-chars

# =============================================================================
# WEBSOCKET SETTINGS
# =============================================================================
# Maximum concurrent WebSocket connections (None = auto-detect from ENVIRONMENT)
# development: 50, staging: 200, production: 1000
WEBSOCKET_MAX_CONNECTIONS=

# WebSocket ping interval in seconds (None = auto-detect from ENVIRONMENT)
# development: 30, staging/production: 20
WEBSOCKET_PING_INTERVAL=

# WebSocket ping timeout in seconds (None = auto-detect from ENVIRONMENT)
# All environments: 10
WEBSOCKET_PING_TIMEOUT=

# =============================================================================
# LOGGING SETTINGS
# =============================================================================
# Log level (None = auto-detect from ENVIRONMENT)
# Options: DEBUG, INFO, WARNING, ERROR
# development: DEBUG, staging: INFO, production: WARNING
LOG_LEVEL=
